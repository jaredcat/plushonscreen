{
  "name": "plushonscreen",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check . && astro check && node --experimental-strip-types scripts/validate-sightings.ts",
    "optimize-images": "node --experimental-strip-types scripts/optimize-images.ts",
    "ci": "biome ci .",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.5.0",
    "@types/node": "^25.9.3",
    "husky": "9.1.7",
    "node-addon-api": "^8.8.0",
    "sharp": "^0.35.1",
    "typescript": "6.0.3",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "sharp": "^0.35.1"
  }
}
