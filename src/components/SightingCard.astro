---
import { Image } from 'astro:assets';
import { formatTvEpisodeLabel } from '../lib/sighting-naming';
import { plushById } from '../plushes';

interface Props {
  slug: string;
  title: string;
  year?: number;
  mediaType: string;
  plush: string;
  confidence: string;
  season?: number;
  episode?: number;
  screenshot?: ImageMetadata;
}

const {
  slug,
  title,
  year,
  mediaType,
  plush,
  confidence,
  season,
  episode,
  screenshot,
} = Astro.props;
const p = plushById(plush);

const typeLabel: Record<string, string> = {
  movie: 'Movie',
  tv: 'TV',
  short: 'Short',
  game: 'Game',
  other: 'Other',
};

const tvEpisode =
  mediaType === 'tv' && season != null && episode != null
    ? formatTvEpisodeLabel(season, episode)
    : null;

const metaParts = [
  year != null ? String(year) : null,
  typeLabel[mediaType] ?? mediaType,
  tvEpisode,
].filter(Boolean);
const metaLine = metaParts.join(' · ');
---

<a
  href={`/sightings/${slug}`}
  class="card"
  data-plush={plush}
  data-type={mediaType}
  data-year={year ?? ''}
  data-confidence={confidence}
>
  <div class="card-shot">
    {screenshot ? (
        <Image
          src={screenshot}
          alt={`${p?.name ?? 'Plush'} in ${title}`}
          width={screenshot.width}
          height={screenshot.height}
        />
      ) : (
        <img
          src="/missing.png"
          alt={`Screenshot needed for ${title}`}
          class="missing-shot"
          width={520}
          height={293}
          loading="lazy"
        />
      )}
  </div>
  <div class="card-body">
    <div class="card-title">{title}</div>
    {metaLine && <div class="card-meta">{metaLine}</div>}
    <div class="card-badges">
      <span class={`badge badge--${confidence}`}>{confidence}</span>
      {p && <span class="badge badge--type">{p.emoji} {p.name}</span>}
    </div>
  </div>
</a>
