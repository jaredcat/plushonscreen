#!/bin/sh
staged=$(git diff --cached --name-only --diff-filter=ACMR)

npx biome check --staged --write --no-errors-on-unmatched --files-ignore-unknown=true

# Resize/compress staged sighting screenshots (high quality, smaller file size).
node --experimental-strip-types scripts/optimize-images.ts

# Hook scripts update the working tree but not the index; re-stage so fixes land in the commit.
if [ -n "$staged" ]; then
  echo "$staged" | xargs git add
fi
