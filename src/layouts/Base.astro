---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'PlushOnScreen',
  description = 'A community-curated database of IKEA plush sightings in movies, TV, and beyond. Spot the snake.',
} = Astro.props;

const fullTitle =
  title === 'PlushOnScreen' ? title : `${title} — PlushOnScreen`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <meta property="og:title" content={fullTitle}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ctext y='14' font-size='14'%3E%F0%9F%90%8D%3C/text%3E%3C/svg%3E"
    >
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a href="/" class="logo">Plush<span class="snake">On</span>Screen</a>
        <nav class="nav">
          <a href="/sightings">Sightings</a>
          <a href="/plushes">The Cast</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span
          >© {new Date().getFullYear()} PlushOnScreen — a fan project, not
          affiliated with IKEA.</span
        >
        <span>
          <a
            href="https://github.com/jaredcat/plushonscreen/issues/new?template=sighting.yml"
            >Submit a sighting →</a
          >
        </span>
      </div>
    </footer>
  </body>
</html>
